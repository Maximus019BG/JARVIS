# JARVIS Hardware AI Integration Configuration
# Copy this file to .env and customize values

# ============================================
# AI Provider Configuration
# ============================================

# AI provider to use: google | ollama
AI_PROVIDER=google

# Google AI (Gemini) configuration
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_api_key_here

# Google model to use (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
AI_GOOGLE_MODEL=gemini-2.0-flash

# Ollama configuration (fallback or primary)
AI_OLLAMA_MODEL=gemma3:1b
AI_OLLAMA_HOST=http://localhost:11434

# Generation parameters
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ============================================
# Text-to-Speech Configuration
# ============================================

# TTS engine: pyttsx3 | gtts | disabled
TTS_ENGINE=pyttsx3

# pyttsx3 settings
TTS_RATE=150
TTS_VOLUME=1.0

# gTTS settings
TTS_LANGUAGE=en

# ============================================
# Security Configuration
# ============================================

# Security level: high | medium | low
SECURITY_LEVEL=high

# Allowed file paths (comma-separated)
# Files outside these paths cannot be accessed
SECURITY_ALLOWED_PATHS=./data,./temp,./blueprints

# Blocked paths (comma-separated)
# Access to these paths is always denied
SECURITY_BLOCKED_PATHS=/etc,/sys,/proc,C:\Windows

# Maximum file size in MB for read/write operations
SECURITY_MAX_FILE_SIZE_MB=10

# Enable audit logging
SECURITY_ENABLE_AUDIT_LOG=true
SECURITY_AUDIT_LOG_PATH=audit.log

# ============================================
# Application Configuration
# ============================================

# Application name
APP_NAME=JARVIS Hardware

# Debug mode
DEBUG=false

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Data directory for storing files
DATA_DIR=./data

# ============================================
# Theme Configuration (optional)
# ============================================

THEME_PRIMARY_COLOR=#007bff
THEME_SECONDARY_COLOR=#6c757d
THEME_BACKGROUND_COLOR=#ffffff
THEME_TEXT_COLOR=#000000
THEME_ACCENT_COLOR=#28a745

# ============================================
# Blueprint Sync Configuration
# ============================================

# Sync server URL
JARVIS_SYNC_SERVER_URL=https://api.jarvis.example.com

# Sync interval in minutes
JARVIS_SYNC_INTERVAL=5

# Request timeout in seconds
JARVIS_SYNC_TIMEOUT=30

# Enable offline mode (true/false)
JARVIS_SYNC_OFFLINE=true

# Verify TLS certificates (true/false)
JARVIS_SYNC_VERIFY_TLS=true

# ============================================
# Vision / Gesture Control Configuration
# ============================================

# Enable gesture control (requires camera)
VISION_ENABLED=false

# Camera settings
VISION_CAMERA_WIDTH=640
VISION_CAMERA_HEIGHT=480
VISION_CAMERA_FPS=30
VISION_CAMERA_ROTATION=0

# Hand detection settings
VISION_MAX_HANDS=2
VISION_DETECTION_CONFIDENCE=0.5
VISION_TRACKING_CONFIDENCE=0.5
VISION_MODEL_COMPLEXITY=0

# Gesture settings (minimum time between same gesture in ms)
VISION_GESTURE_COOLDOWN_MS=300
